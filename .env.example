# Copia este archivo como ".env" y completa los valores reales.
# El ".env" NO se sube al repo: contiene claves secretas.

# ── Appwrite ──
APPWRITE_ENDPOINT=
APPWRITE_PROJECT_ID=
APPWRITE_API_KEY=
APPWRITE_DATABASE_ID=
APPWRITE_POST_COLLECTION_ID=
APPWRITE_DETAILS_COLLECTION_ID=
APPWRITE_STORAGE_BUCKET_ID=

# ── AWS Rekognition ──
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
